---
import Footer from '../components/Footer.astro'
import Nav from '../components/Nav.astro'
import Layout from '../layouts/Layout.astro'

const CATALOG_URL = 'https://raw.githubusercontent.com/aj47/dotagents-hub/main/catalog.json'
const BUNDLE_BASE_URL = 'https://raw.githubusercontent.com/aj47/dotagents-hub/main/bundles'

// Fetch real catalog at build time (falls back to empty if unavailable)
let catalog: any = { items: [] }
try {
  const res = await fetch(CATALOG_URL)
  if (res.ok) catalog = await res.json()
} catch (e) {
  console.warn('Could not fetch catalog:', e)
}

const bundles = catalog.items ?? []
const totalComponents = bundles.reduce(
  (acc: any, b: any) => {
    acc.agentProfiles += b.componentCounts?.agentProfiles ?? 0
    acc.mcpServers += b.componentCounts?.mcpServers ?? 0
    acc.skills += b.componentCounts?.skills ?? 0
    acc.repeatTasks += b.componentCounts?.repeatTasks ?? 0
    acc.memories += b.componentCounts?.memories ?? 0
    return acc
  },
  { agentProfiles: 0, mcpServers: 0, skills: 0, repeatTasks: 0, memories: 0 }
)

const dateFormatter = new Intl.DateTimeFormat('en', { month: 'short', day: 'numeric', year: 'numeric' })
---

<Layout
  title=".agents Hub — Discover and install .dotagents bundles"
  description="Browse installable .dotagents bundles from TechFriend AJ and the community. One-click install into DotAgents."
  url="https://hub.dotagentsprotocol.com"
  ogImage="https://hub.dotagentsprotocol.com/og-hub.png"
>
  <Nav />

  <main class="pt-24">
    <!-- Header -->
    <section class="border-b border-border pb-6">
      <div class="max-w-4xl mx-auto px-6">
        <div class="text-fg-dim text-xs mb-4 flex items-center gap-3">
          <span>PUBLIC CATALOG</span>
          <span class="text-border">·</span>
          <span>hub.dotagentsprotocol.com</span>
        </div>
        <h1 class="text-3xl md:text-4xl font-bold text-white leading-tight mb-4 font-sans tracking-tight">
          .agents Hub
        </h1>
      </div>
    </section>

    <!-- Search + Bundles -->
    <section class="border-b border-border py-4">
      <div class="max-w-4xl mx-auto px-6">
        <div class="spec-card rounded-md p-3">
          <input
            id="hub-search"
            type="search"
            placeholder="Search bundles, authors, or tags"
            class="w-full rounded-md border border-border bg-bg px-4 py-2 text-[13px] text-fg placeholder:text-fg-dim outline-none focus:border-accent-cyan"
          />
        </div>

        <div class="mt-6">
          <div class="flex flex-col gap-2 mb-6 md:flex-row md:items-end md:justify-between">
            <div>
              <p class="text-fg-dim text-[11px] uppercase tracking-[0.18em] mb-2">Starter packs</p>
              <h2 class="text-fg font-bold font-sans">Ready-to-install agent setups</h2>
            </div>
            <p class="text-fg-muted text-[13px] max-w-xl">
              Built by TechFriend AJ. Click Inspect to preview agents, skills, and tasks before installing.
            </p>
          </div>

          <!-- Loading state (shown until JS hydrates) -->
          <div id="hub-loading" class="text-fg-dim text-[13px] py-8 text-center">Loading bundles…</div>

          <div id="hub-results" class="grid gap-5 md:grid-cols-2 hidden">
            {bundles.map((bundle: any) => (
              <article
                class="spec-card rounded-md p-5 flex flex-col gap-4"
                data-bundle-card
                data-bundle-id={bundle.id}
                data-bundle-url={`${BUNDLE_BASE_URL}/${bundle.id}.dotagents`}
                data-searchable-text={[bundle.name, bundle.summary, bundle.author?.displayName, bundle.author?.handle ?? '', ...(bundle.tags ?? [])].join(' ').toLowerCase()}
              >
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <p class="text-[11px] uppercase tracking-[0.18em] text-fg-dim mb-2">bundle · v{bundle.bundleVersion}</p>
                    <h2 class="text-lg text-white font-sans font-semibold leading-snug">{bundle.name}</h2>
                  </div>
                  <span class="text-[11px] text-accent-teal whitespace-nowrap">
                    {bundle.updatedAt ? dateFormatter.format(new Date(bundle.updatedAt)) : ''}
                  </span>
                </div>

                <p class="text-fg-muted text-[13px] leading-relaxed">{bundle.summary}</p>

                <div class="text-xs text-fg-muted flex flex-wrap items-center gap-2">
                  {bundle.author?.url ? (
                    <a href={bundle.author.url} target="_blank" rel="noopener" class="hover:text-fg">
                      {bundle.author.displayName}
                    </a>
                  ) : (
                    <span>{bundle.author?.displayName}</span>
                  )}
                  {bundle.author?.handle && <span class="text-accent-cyan">{bundle.author.handle}</span>}
                  <span class="text-border">│</span>
                  <span>{bundle.componentCounts?.agentProfiles ?? 0} agents</span>
                  <span class="text-border">·</span>
                  <span>{bundle.componentCounts?.mcpServers ?? 0} MCP</span>
                  <span class="text-border">·</span>
                  <span>{bundle.componentCounts?.skills ?? 0} skills</span>
                </div>

                <div class="text-xs text-fg-dim flex flex-wrap items-center gap-2">
                  <span>{bundle.componentCounts?.repeatTasks ?? 0} tasks</span>
                  <span class="text-border">·</span>
                  <span>{bundle.componentCounts?.memories ?? 0} memories</span>
                  {bundle.tags && bundle.tags.length > 0 && (
                    <>
                      <span class="text-border">│</span>
                      {bundle.tags.slice(0, 3).map((tag: string) => (
                        <span class="bg-surface border border-border rounded px-1.5 py-0.5 text-[10px] text-fg-dim">{tag}</span>
                      ))}
                    </>
                  )}
                </div>

                <div class="flex items-center gap-3 mt-auto pt-2 border-t border-border">
                  <button
                    class="inspect-btn text-[12px] text-accent-cyan hover:text-white border border-accent-cyan/30 hover:border-accent-cyan rounded px-3 py-1.5 transition-colors"
                    data-bundle-id={bundle.id}
                    data-bundle-name={bundle.name}
                    data-bundle-url={`${BUNDLE_BASE_URL}/${bundle.id}.dotagents`}
                  >
                    Inspect ↗
                  </button>
                  <a
                    href={`dotagents://install?bundle=${encodeURIComponent(`${BUNDLE_BASE_URL}/${bundle.id}.dotagents`)}`}
                    class="text-[12px] text-fg-muted hover:text-white border border-border hover:border-fg-muted rounded px-3 py-1.5 transition-colors"
                  >
                    Install bundle →
                  </a>
                  <span class="text-fg-dim text-[11px] ml-auto">
                    {bundle.artifact?.sizeBytes ? `${Math.round(bundle.artifact.sizeBytes / 1024)} KB` : ''}
                  </span>
                </div>
              </article>
            ))}
          </div>

          <div id="hub-empty-state" class="hidden text-fg-dim text-[13px] py-8 text-center">
            No bundles match your search yet.
          </div>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="border-b border-border py-8">
      <div class="max-w-4xl mx-auto px-6">
        <div class="grid gap-4 md:grid-cols-4">
          <div class="spec-card rounded-md p-4 md:col-span-4">
            <p class="text-fg-dim text-[11px] uppercase tracking-[0.18em] mb-2">Catalog totals</p>
            <p class="text-white text-xl font-sans font-semibold mb-1">{bundles.length} installable bundles</p>
            <p class="text-fg-muted text-[13px]">Built by TechFriend AJ · Community submissions welcome via PR</p>
          </div>
          <div class="spec-card rounded-md p-4">
            <p class="text-fg-dim text-[11px] uppercase tracking-[0.18em] mb-2">Agents</p>
            <p class="text-white text-xl font-sans font-semibold">{totalComponents.agentProfiles}</p>
          </div>
          <div class="spec-card rounded-md p-4">
            <p class="text-fg-dim text-[11px] uppercase tracking-[0.18em] mb-2">MCP</p>
            <p class="text-white text-xl font-sans font-semibold">{totalComponents.mcpServers}</p>
          </div>
          <div class="spec-card rounded-md p-4">
            <p class="text-fg-dim text-[11px] uppercase tracking-[0.18em] mb-2">Skills</p>
            <p class="text-white text-xl font-sans font-semibold">{totalComponents.skills}</p>
          </div>
          <div class="spec-card rounded-md p-4">
            <p class="text-fg-dim text-[11px] uppercase tracking-[0.18em] mb-2">Tasks</p>
            <p class="text-white text-xl font-sans font-semibold">{totalComponents.repeatTasks}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Contribute CTA -->
    <section class="pb-16 pt-10">
      <div class="max-w-4xl mx-auto px-6">
        <div class="spec-card rounded-md p-6 flex flex-col md:flex-row md:items-center md:justify-between gap-5">
          <div>
            <p class="text-[11px] uppercase tracking-[0.18em] text-fg-dim mb-2">Publish your bundle</p>
            <h2 class="text-fg font-bold font-sans mb-2">Share your agent setup with the community.</h2>
            <p class="text-fg-muted text-[13px] leading-relaxed max-w-2xl">
              Export your setup from DotAgents, add it to <span class="text-accent-cyan">aj47/dotagents-hub</span>, and open a PR. Your bundle will appear here automatically.
            </p>
          </div>
          <div class="flex flex-wrap items-center gap-4 text-xs">
            <a href="https://github.com/aj47/dotagents-hub" target="_blank" rel="noopener" class="text-accent-cyan hover:text-white">Submit a bundle →</a>
            <a href="https://dotagentsprotocol.com/#formats" class="text-fg-muted hover:text-fg">.agents Protocol format ↗</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <!-- Inspector Modal -->
  <div id="inspect-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-black/70 backdrop-blur-sm">
    <div class="bg-bg border border-border rounded-lg w-full max-w-2xl max-h-[85vh] flex flex-col shadow-2xl">
      <!-- Modal Header -->
      <div class="flex items-center justify-between px-6 py-4 border-b border-border flex-shrink-0">
        <div>
          <p class="text-fg-dim text-[11px] uppercase tracking-[0.18em] mb-1">bundle inspector</p>
          <h3 id="modal-bundle-name" class="text-white font-sans font-semibold text-lg"></h3>
        </div>
        <button id="modal-close" class="text-fg-dim hover:text-white text-xl leading-none px-2 py-1">✕</button>
      </div>

      <!-- Modal Body -->
      <div id="modal-body" class="flex-1 overflow-y-auto px-6 py-4 text-[13px]">
        <div id="modal-loading" class="text-fg-dim py-8 text-center">Fetching bundle…</div>
        <div id="modal-content" class="hidden flex flex-col gap-4"></div>
        <div id="modal-error" class="hidden text-red-400 py-8 text-center"></div>
      </div>

      <!-- Modal Footer -->
      <div class="flex items-center gap-3 px-6 py-4 border-t border-border flex-shrink-0">
        <a id="modal-install-btn" href="#" class="text-[12px] text-fg-muted hover:text-white border border-border hover:border-fg-muted rounded px-4 py-2 transition-colors">
          Install bundle →
        </a>
        <span id="modal-bundle-meta" class="text-fg-dim text-[11px] ml-auto"></span>
      </div>
    </div>
  </div>

  <script is:inline>
    // ── Search ──────────────────────────────────────────────────────────────
    const searchInput = document.querySelector('#hub-search')
    const cards = Array.from(document.querySelectorAll('[data-bundle-card]'))
    const emptyState = document.querySelector('#hub-empty-state')
    const hubResults = document.querySelector('#hub-results')
    const hubLoading = document.querySelector('#hub-loading')

    // Show bundles (hide loading)
    if (hubLoading) hubLoading.classList.add('hidden')
    if (hubResults) hubResults.classList.remove('hidden')

    if (searchInput && cards.length) {
      const applyFilter = () => {
        const query = searchInput.value.trim().toLowerCase()
        let visibleCount = 0
        cards.forEach((card) => {
          const haystack = card.getAttribute('data-searchable-text') || ''
          const matches = !query || haystack.includes(query)
          card.style.display = matches ? '' : 'none'
          if (matches) visibleCount++
        })
        if (emptyState) emptyState.classList.toggle('hidden', visibleCount > 0)
      }
      searchInput.addEventListener('input', applyFilter)
    }

    // ── Inspector Modal ──────────────────────────────────────────────────────
    const modal = document.querySelector('#inspect-modal')
    const modalClose = document.querySelector('#modal-close')
    const modalBundleName = document.querySelector('#modal-bundle-name')
    const modalBundleMeta = document.querySelector('#modal-bundle-meta')
    const modalInstallBtn = document.querySelector('#modal-install-btn')
    const modalLoading = document.querySelector('#modal-loading')
    const modalContent = document.querySelector('#modal-content')
    const modalError = document.querySelector('#modal-error')

    function openModal() {
      modal.classList.remove('hidden')
      modal.classList.add('flex')
      document.body.style.overflow = 'hidden'
    }

    function closeModal() {
      modal.classList.add('hidden')
      modal.classList.remove('flex')
      document.body.style.overflow = ''
    }

    modalClose?.addEventListener('click', closeModal)
    modal?.addEventListener('click', (e) => { if (e.target === modal) closeModal() })
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal() })

    function renderSection(icon, title, content) {
      return `
        <details class="border border-border rounded-md overflow-hidden" open>
          <summary class="flex items-center gap-2 px-4 py-3 cursor-pointer hover:bg-surface text-fg font-sans font-medium select-none">
            <span>${icon}</span><span>${title}</span>
          </summary>
          <div class="px-4 pb-4 pt-2 border-t border-border">${content}</div>
        </details>`
    }

    function escHtml(str) {
      return String(str ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
    }

    function renderBundle(data) {
      const sections = []

      // Agent Profiles
      if (data.agentProfiles?.length) {
        const agentHtml = data.agentProfiles.map(a => `
          <details class="mb-3 border border-border/50 rounded">
            <summary class="px-3 py-2 cursor-pointer text-fg-muted hover:text-fg text-[12px] select-none">
              🤖 ${escHtml(a.displayName || a.name)}
              <span class="text-fg-dim ml-2">${escHtml(a.description || '')}</span>
            </summary>
            <div class="px-3 pb-3 pt-1">
              ${a.systemPrompt ? `<pre class="text-[11px] text-fg-muted bg-surface border border-border rounded p-3 overflow-x-auto whitespace-pre-wrap leading-relaxed">${escHtml(a.systemPrompt)}</pre>` : ''}
              ${a.guidelines ? `<p class="text-[11px] text-fg-dim mt-2"><strong class="text-fg-muted">Guidelines:</strong> ${escHtml(a.guidelines)}</p>` : ''}
            </div>
          </details>`).join('')
        sections.push(renderSection('🤖', `Agent Profiles (${data.agentProfiles.length})`, agentHtml))
      }

      // MCP Servers
      if (data.mcpServers?.length) {
        const mcpHtml = data.mcpServers.map(m => `
          <div class="mb-2 text-[12px]">
            <span class="text-fg-muted font-medium">${escHtml(m.name)}</span>
            <span class="text-fg-dim ml-2">${escHtml(m.command)} ${(m.args||[]).join(' ')}</span>
          </div>`).join('')
        sections.push(renderSection('🔧', `MCP Servers (${data.mcpServers.length})`, mcpHtml))
      }

      // Skills
      if (data.skills?.length) {
        const skillHtml = data.skills.map(s => `
          <details class="mb-3 border border-border/50 rounded">
            <summary class="px-3 py-2 cursor-pointer text-fg-muted hover:text-fg text-[12px] select-none">
              🧠 ${escHtml(s.name)} <span class="text-fg-dim ml-2">${escHtml(s.description || '')}</span>
            </summary>
            <div class="px-3 pb-3 pt-1">
              <pre class="text-[11px] text-fg-muted bg-surface border border-border rounded p-3 overflow-x-auto whitespace-pre-wrap leading-relaxed">${escHtml(s.instructions)}</pre>
            </div>
          </details>`).join('')
        sections.push(renderSection('🧠', `Skills (${data.skills.length})`, skillHtml))
      }

      // Repeat Tasks
      if (data.repeatTasks?.length) {
        const taskHtml = data.repeatTasks.map(t => `
          <details class="mb-3 border border-border/50 rounded">
            <summary class="px-3 py-2 cursor-pointer text-fg-muted hover:text-fg text-[12px] select-none">
              ⏰ ${escHtml(t.name)} <span class="text-fg-dim ml-2">every ${t.intervalMinutes >= 10080 ? 'week' : t.intervalMinutes >= 1440 ? 'day' : t.intervalMinutes + 'min'} · disabled by default</span>
            </summary>
            <div class="px-3 pb-3 pt-1">
              <pre class="text-[11px] text-fg-muted bg-surface border border-border rounded p-3 overflow-x-auto whitespace-pre-wrap leading-relaxed">${escHtml(t.prompt)}</pre>
            </div>
          </details>`).join('')
        sections.push(renderSection('⏰', `Repeat Tasks (${data.repeatTasks.length})`, taskHtml))
      }

      return sections.join('')
    }

    document.querySelectorAll('.inspect-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const bundleUrl = btn.getAttribute('data-bundle-url')
        const bundleName = btn.getAttribute('data-bundle-name')

        if (modalBundleName) modalBundleName.textContent = bundleName
        if (modalInstallBtn) modalInstallBtn.href = `dotagents://install?bundle=${encodeURIComponent(bundleUrl)}`
        if (modalBundleMeta) modalBundleMeta.textContent = ''

        modalLoading.classList.remove('hidden')
        modalContent.classList.add('hidden')
        modalError.classList.add('hidden')
        modalContent.innerHTML = ''

        openModal()

        try {
          const res = await fetch(bundleUrl)
          if (!res.ok) throw new Error(`HTTP ${res.status}`)
          const data = await res.json()

          const sizeKb = Math.round((await (await fetch(bundleUrl)).blob()).size / 1024)
          if (modalBundleMeta) modalBundleMeta.textContent = `v${data.manifest?.version ?? 1} · ${sizeKb} KB`

          modalContent.innerHTML = renderBundle(data)
          modalLoading.classList.add('hidden')
          modalContent.classList.remove('hidden')
        } catch (err) {
          modalLoading.classList.add('hidden')
          modalError.textContent = `Could not load bundle: ${err.message}`
          modalError.classList.remove('hidden')
        }
      })
    })
  </script>

  <Footer />
</Layout>
