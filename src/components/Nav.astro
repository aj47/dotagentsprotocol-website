---
const isHubPage = Astro.url.pathname === '/hub' || Astro.url.pathname === '/hub/'
const siteHref = 'https://dotagentsprotocol.com'
const hubHref = 'https://hub.dotagentsprotocol.com'
const sectionHref = (id: string) => (isHubPage ? `${siteHref}/#${id}` : `/#${id}`)
---
<nav class="fixed top-0 left-0 right-0 z-50 bg-bg/90 backdrop-blur-sm border-b border-border">
  <div class="max-w-4xl mx-auto px-6 h-12 flex items-center justify-between">
    <a href={isHubPage ? siteHref : '/'} class="text-fg font-bold hover:text-white">.agents Protocol</a>
    <div class="hidden md:flex items-center gap-6 text-fg-muted text-xs">
      <a href={sectionHref('overview')} class="hover:text-fg">overview</a>
      <a href={sectionHref('ecosystem')} class="hover:text-fg">ecosystem</a>
      <a href={sectionHref('structure')} class="hover:text-fg">structure</a>
      <a href={sectionHref('formats')} class="hover:text-fg">formats</a>
      <a href={sectionHref('interop')} class="hover:text-fg">interop</a>
      <a href={sectionHref('get-started')} class="hover:text-fg">get started</a>
      <a href={hubHref} class={isHubPage ? 'text-fg' : 'hover:text-fg'}>.agents Hub</a>
      <span class="text-border">│</span>
      <a href="https://github.com/aj47/dotagentsprotocol-website" target="_blank" rel="noopener" class="hover:text-fg">github ↗</a>
    </div>
  </div>
</nav>

